# Host user — so Docker-created files are owned by you, not root
# Run: id -u && id -g   to find your values
UID=1000
GID=1000

# Hugging Face — required for speaker diarization (pyannote.audio)
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=

# Logfire — optional, enables observability traces
# Get yours at https://logfire.pydantic.dev
LOGFIRE_TOKEN=

# Optional: Ridge JSON trained with scripts/train_tts_duration_predictor.py (better segment duration guesses).
# In Docker Compose the API mounts ./foreign_whispers → /app/foreign_whispers, so a model saved beside
# foreign_whispers/alignment.py becomes:
# FW_TTS_DURATION_MODEL=/app/foreign_whispers/tts_duration_ridge.json
# Or put the file under pipeline_data (mounted at /app/pipeline_data).
# FW_TTS_DURATION_MODEL=

# Chatterbox HTTP timeouts (seconds) when the API calls a remote GPU over SSH tunnels.
# FW_CHATTERBOX_HTTP_CONNECT_TIMEOUT=10
# FW_CHATTERBOX_HTTP_READ_TIMEOUT=120

# No remote Chatterbox? Force bundled Coqui TTS inside the API container (slow on CPU but works).
# Also remove/disable FW_CHATTERBOX_SKIP_HEAVY_PROBE — if it stays "1" with no reachable server,
# the API commits to HTTP TTS only and sidecars fill with synth failures / raw_duration_s=0.
# FW_TTS_ENGINE=coqui

# Whisper: use bundled OpenAI Whisper in-process (heavy on CPU/RAM vs remote GPU).
# FW_WHISPER_BACKEND=local
